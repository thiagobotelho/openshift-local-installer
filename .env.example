# Caminhos opcionais. Se estiverem no PATH, não precisa preencher.
CRC_BIN=crc
OC_BIN=oc

# Recursos mínimos recomendados para a stack observability local.
CRC_MIN_CPUS=8
CRC_MIN_MEMORY_MIB=24576

# Habilita User Workload Monitoring no ConfigMap cluster-monitoring-config.
# Requer enable-cluster-monitoring=true no CRC antes do start.
ENABLE_USER_WORKLOAD_MONITORING=true

# Namespaces esperados após o App-of-Apps.
EXPECTED_NAMESPACES="openshift-gitops openshift-monitoring openshift-user-workload-monitoring keycloak-dev grafana zabbix observability tempo openshift-logging"
