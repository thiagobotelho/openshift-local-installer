# Caminhos opcionais. Se estiverem no PATH, não precisa preencher.
CRC_BIN=crc
OC_BIN=oc

# Instalador do OpenShift Local.
CRC_ARCHIVE=bin/crc/crc-linux-amd64.tar.xz
PULL_SECRET_FILE=./config/pull-secret
INSTALL_DIR=/usr/local/bin

# Perfil recomendado para a stack completa em CRC/OpenShift Local.
# Ajuste para baixo somente se for sincronizar poucos componentes por vez.
CRC_CPUS=10
CRC_MEMORY=40960
CRC_DISK_SIZE=200
ENABLE_CLUSTER_MONITORING=true

# Validação do CRC. Deve acompanhar ou ficar abaixo do perfil acima.
CRC_MIN_CPUS=10
CRC_MIN_MEMORY_MIB=40960

# Bootstrap opcional do OpenShift GitOps feito pelo install.sh --deploy-gitops.
ARGOCD_GITOPS_REF=main
ARGOCD_GITOPS_OVERLAY=desenvolvimento
TIMEOUT_SECONDS=600
SLEEP_SECONDS=5

# User Workload Monitoring fica desativado por padrão nesta stack porque os
# workloads são coletados pelo prometheus-gitops/MonitoringStack.
ENABLE_USER_WORKLOAD_MONITORING=false

# Namespaces esperados após o App-of-Apps.
EXPECTED_NAMESPACES="openshift-gitops openshift-monitoring keycloak-dev grafana zabbix observability tempo openshift-logging observability-apps pyroscope"
